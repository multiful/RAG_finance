# Railway Variables 참고 (비밀값은 대시보드에만 입력)
# Root Directory = app/backend 권장
#
# --- 필수 ---
# OPENAI_API_KEY=
# SUPABASE_URL=
# SUPABASE_KEY=
# SUPABASE_SERVICE_KEY=   (서버 작업·RLS 시 권장)
# REDIS_URL=              (없으면 인메모리 캐시)
# CORS_ORIGINS=https://your-app.vercel.app
#
# 기본은 OPENAI_MODEL=gpt-4o-mini, OPENAI_MODEL_QA 비움(동일 모델). 4o는 OPENAI_MODEL_QA=gpt-4o 로만.
# ENABLE_QUERY_HYDE=false       — 질문당 LLM 1회 절감(골든셋·프로덕션 권장: false, 코드가 약어 보강으로 리콜 보완)
# ENABLE_RERANKING=false      — 슬림 이미지(sentence-transformers 없음)와 정합
# ENABLE_FAST_ANSWERABILITY=true — 답변가능성 LLM 생략 가능(겹침·유사도 충족 시)
# TOP_K_RETRIEVAL=24          — 기본 24(골든 리콜). 더 넓히면 28~32
# FAST_ANSWERABILITY_MIN_OVERLAP=0.22 — 골든 정확도(오검색 빠른통과 억제) 기본과 동일
# LANGCHAIN_TRACING_V2=false    — 키 없을 때 오버헤드↓ (LangSmith 쓰면 true)
#
# 선택: LLAMAPARSE_API_KEY, LANGSMITH_API_KEY, TAVILY_API_KEY, SLACK_WEBHOOK_URL
# /health 상세 점검: GET /health?refresh=true
