# Railway Variables 참고 (비밀값은 대시보드에만 입력)
# Root Directory = app/backend 권장
#
# --- 필수 ---
# OPENAI_API_KEY=
# SUPABASE_URL=
# SUPABASE_KEY=
# SUPABASE_SERVICE_KEY=   (서버 작업·RLS 시 권장)
# REDIS_URL=              (없으면 인메모리 캐시)
# CORS_ORIGINS=https://your-app.vercel.app
#
# 기본은 OPENAI_MODEL=gpt-4o-mini. 코드 기본값: OPENAI_MODEL_QA·RAGAS_EVAL_MODEL=gpt-5.1 (고품질·TPM 여유, 표 대비)
# 비용·지연 우선: OPENAI_MODEL_QA= 와 RAGAS_EVAL_MODEL= 를 비우면 OPENAI_MODEL(mini)과 동일
# 또는 OPENAI_MODEL_QA=gpt-5-mini 등으로만 조정
# Ragas TimeoutError 시: RAGAS_RUN_TIMEOUT=300, RAGAS_MAX_WORKERS=4 (코드 기본) 유지 또는 타임아웃 상향
#
# ENABLE_QUERY_HYDE=false       — 질문당 LLM 1회 절감(골든셋·프로덕션 권장: false, 코드가 약어 보강으로 리콜 보완)
# ENABLE_RERANKING=false      — 슬림 이미지(sentence-transformers 없음)와 정합
# ENABLE_FAST_ANSWERABILITY=true — 답변가능성 LLM 생략 가능(겹침·유사도 충족 시)
# TOP_K_RETRIEVAL=30          — 코드 기본 30(골든 리콜). HYBRID_SIMILARITY_THRESHOLD=0.16 과 함께 튜닝
# FAST_ANSWERABILITY_MIN_OVERLAP=0.22 — 골든 정확도(오검색 빠른통과 억제)
# LANGCHAIN_TRACING_V2=false    — 키 없을 때 오버헤드↓ (LangSmith 쓰면 true)
# ENABLE_QA_RESPONSE_CACHE=true — HyDE 꺼진 동일 질문 Redis 캐시(기본 180s, 문서 갱신 직후엔 잠깐 오래된 답 가능)
# QA_CACHE_TTL_SECONDS=180
#
# 선택: LLAMAPARSE_API_KEY, LANGSMITH_API_KEY, TAVILY_API_KEY, SLACK_WEBHOOK_URL
# /health 상세 점검: GET /health?refresh=true
